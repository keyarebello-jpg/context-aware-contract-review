{
  "rules": [
    {
      "rule_id": "GDPR-01",
      "name": "Data Processing Agreement",
      "regulation": "GDPR Article 28",
      "trigger_conditions": {
        "processes_personal_data": [
          true
        ]
      },
      "required_clause_types": [
        "data_processing_agreement",
        "data_processing"
      ],
      "required_keywords": [
        "data processing agreement",
        "article 28",
        "processor",
        "controller"
      ],
      "severity": "high",
      "explanation": "Where personal data is processed for service delivery, the contract should contain structured data processing obligations consistent with GDPR Article 28."
    },
    {
      "rule_id": "GDPR-02",
      "name": "Data Subject Rights and Breach Support",
      "regulation": "GDPR Articles 15 to 22 and 33",
      "trigger_conditions": {
        "processes_personal_data": [
          true
        ],
        "cross_border_data_transfer": [
          true
        ]
      },
      "required_clause_types": [
        "data_subject_rights",
        "breach_notification"
      ],
      "required_keywords": [
        "data subject rights",
        "breach notification",
        "erasure",
        "access request"
      ],
      "severity": "high",
      "explanation": "The contract should address support for data subject rights and timely breach notification where personal data is processed across jurisdictions."
    },
    {
      "rule_id": "PSD2-01",
      "name": "Payment Security and Authentication",
