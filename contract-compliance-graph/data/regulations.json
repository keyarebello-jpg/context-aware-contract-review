        "regulatory_exposure.Public_Procurement": [
          true
        ]
      },
      "required_clause_types": [
        "audit_rights",
        "regulatory_cooperation"
      ],
      "required_keywords": [
        "audit",
        "inspect records",
        "regulator",
        "supervisory body"
      ],
      "severity": "critical",
      "explanation": "Where infrastructure is provided to a public authority, the contract should include audit and cooperation mechanisms."
    },
    {
