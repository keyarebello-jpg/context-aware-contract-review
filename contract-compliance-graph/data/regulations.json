          "fraud detection",
          "identity verification"
        ]
      },
      "required_clause_types": [
        "regulatory_cooperation",
        "record_keeping"
      ],
      "required_keywords": [
        "cooperate",
        "record keeping",
        "identity verification",
        "transaction monitoring"
      ],
      "severity": "medium",
      "explanation": "Where services include fraud monitoring and identity controls, the contract should support regulatory cooperation and records management."
    },
    {
      "rule_id": "PROC-01",
      "name": "Public Authority Audit Rights",
      "regulation": "Public Procurement / Public Finance Controls",
