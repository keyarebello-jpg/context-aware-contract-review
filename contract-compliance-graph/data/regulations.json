        "activities": [
          "payment initiation",
          "cross-border settlement",
          "data-sharing infrastructure"
        ]
      },
      "required_clause_types": [
        "service_availability",
        "incident_notification",
        "business_continuity"
      ],
      "required_keywords": [
        "incident",
        "service availability",
        "business continuity",
        "disaster recovery"
      ],
      "severity": "critical",
      "explanation": "Critical digital infrastructure contracts should include resilience, continuity, and incident-management obligations."
    },
    {
