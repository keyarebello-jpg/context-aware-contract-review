          "account-to-account payment routing",
          "open banking API aggregation"
        ]
      },
      "required_clause_types": [
        "security",
        "authentication",
        "liability"
      ],
      "required_keywords": [
        "security",
        "authentication",
        "unauthorised transaction",
        "payment initiation"
      ],
      "severity": "high",
      "explanation": "Payment infrastructure contracts should allocate security and authentication responsibilities for regulated payment activity."
    },
    {
